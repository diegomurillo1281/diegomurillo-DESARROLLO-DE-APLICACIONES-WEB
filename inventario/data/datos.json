import json

ruta_json = "inventario/data/datos.json"


def guardar_json(nombre, precio):

    datos = []

    if os.path.exists(ruta_json):

        with open(ruta_json, "r") as archivo:
            try:
                datos = json.load(archivo)
            except:
                datos = []

    nuevo = {
        "nombre": nombre,
        "precio": precio
